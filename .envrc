# direnv: loads local secrets from AWS Secrets Manager and writes a .env file
# for the Docker `--env-file .env` workflow. Run `direnv allow` after editing.

set -euo pipefail

if ! command -v aws >/dev/null 2>&1; then
  echo "direnv: aws CLI is required" >&2
  exit 1
fi
if ! command -v jq >/dev/null 2>&1; then
  echo "direnv: jq is required" >&2
  exit 1
fi

export AWS_PROFILE=rtm
export AWS_REGION=eu-west-1
export AWS_BUCKET_NAME=prod-eu-west-1-app-data
export HEALTH_PORT=4000

# DISCORD_BOT_TOKEN — local-only secret per developer
_local_secret=$(aws secretsmanager get-secret-value \
  --secret-id local-sports-data-discord-bot \
  --region "$AWS_REGION" \
  --query SecretString --output text)
export DISCORD_BOT_TOKEN=$(echo "$_local_secret" | jq -r .DISCORD_BOT_TOKEN)
unset _local_secret

# BetFair credentials — shared with the prod ECS task
_betfair_secret=$(aws secretsmanager get-secret-value \
  --secret-id prod-eu-west-1-betfair \
  --region "$AWS_REGION" \
  --query SecretString --output text)
export BETFAIR_USERNAME=$(echo "$_betfair_secret" | jq -r .BETFAIR_USERNAME)
export BETFAIR_PASSWORD=$(echo "$_betfair_secret" | jq -r .BETFAIR_PASSWORD)
export BETFAIR_LIVE_APP_KEY=$(echo "$_betfair_secret" | jq -r .BETFAIR_LIVE_APP_KEY)
unset _betfair_secret

# Mirror the exported vars into a .env file so `make docker-*` (which uses
# `--env-file .env`) picks them up. .env is gitignored.
cat > .env <<EOF
AWS_REGION=$AWS_REGION
AWS_BUCKET_NAME=$AWS_BUCKET_NAME
HEALTH_PORT=$HEALTH_PORT
DISCORD_BOT_TOKEN=$DISCORD_BOT_TOKEN
BETFAIR_USERNAME=$BETFAIR_USERNAME
BETFAIR_PASSWORD=$BETFAIR_PASSWORD
BETFAIR_LIVE_APP_KEY=$BETFAIR_LIVE_APP_KEY
EOF
